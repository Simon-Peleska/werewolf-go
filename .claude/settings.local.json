{
  "permissions": {
    "allow": [
      "Bash(run_tests.sh list:*)",
      "Bash(./tools/run_tests.sh list:*)"
    ]
  },
  "enabledMcpjsonServers": [
    "delve"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "go fmt ./..."
          }
        ]
      }
    ]
  },
  "spinnerTipsEnabled": false
}
